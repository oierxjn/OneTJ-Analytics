APP_NAME=OneTJ Data Collector
ENVIRONMENT=test
REQUIRE_HTTPS=false
RATE_LIMIT_PER_MINUTE=16
MAX_PAYLOAD_BYTES=1048576
INGEST_BACKEND=redis
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_STREAM_KEY=collector.events
REDIS_STREAM_MAXLEN=1000000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/onetj_analytics
CONSUMER_GROUP=collector-workers
CONSUMER_NAME=worker-1
BATCH_SIZE=500
FLUSH_INTERVAL_MS=100
CONSUME_BLOCK_MS=1000
